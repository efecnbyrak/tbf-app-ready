// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL")
}

model User {
  id       Int      @id @default(autoincrement())
  username String   @unique
  tckn     String   @unique
  password String
  role     Role     @relation(fields: [roleId], references: [id])
  roleId   Int
  referee  Referee?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  verificationCode String?
  verificationCodeExpiresAt DateTime?
  isVerified Boolean @default(false)
  isApproved Boolean @default(false)
  suspendedUntil DateTime?
  videoProgress VideoProgress[]
  chats ChatSession[]

  @@map("users")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique // "ADMIN" or "REFEREE"
  users User[]

  @@map("roles")
}

model Region {
  id       Int       @id @default(autoincrement())
  name     String    @unique // "Anadolu", "Avrupa", "BGM"
  referees Referee[] // Many-to-many relation implicitly handled by Prisma

  @@map("regions")
}

model Referee {
  id             Int      @id @default(autoincrement())
  user           User     @relation(fields: [userId], references: [id])
  userId         Int      @unique
  tckn           String   @unique
  firstName      String
  lastName       String
  email          String   @unique
  phone          String
  address        String?
  job            String?
  classification String // "A", "B", "C", "IL_HAKEMI", "ADAY_HAKEM"
  officialType   String   @default("REFEREE") // "REFEREE", "TABLE", "OBSERVER", "HEALTH", "STATISTICIAN"
  imageUrl       String?
  regions        Region[]
  forms          AvailabilityForm[]
  assignments    MatchAssignment[]
  examAttempts   ExamAttempt[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("referees")
}

model AvailabilityForm {
  id            Int      @id @default(autoincrement())
  referee       Referee  @relation(fields: [refereeId], references: [id])
  refereeId     Int
  weekStartDate DateTime // The Monday (or specific start) of the week
  status        String   @default("DRAFT") // "DRAFT", "SUBMITTED", "LOCKED"
  days          AvailabilityDay[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([refereeId, weekStartDate]) // One form per week per referee
  @@map("availability_forms")
}

model AvailabilityDay {
  id       Int              @id @default(autoincrement())
  form     AvailabilityForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId   Int
  date     DateTime
  slots    String           // Stores selected time slots e.g. "10:00-13:00,19:00-22:00"
  
  @@map("availability_days")
}

model SystemSetting {
  key         String @id
  value       String
  description String?

  @@map("system_settings")
}

model Match {
  id        Int      @id @default(autoincrement())
  matchCode String   @unique
  league    String
  homeTeam  String
  awayTeam  String
  date      DateTime
  location  String
  
  assignments MatchAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("matches")
}

model MatchAssignment {
  id        Int      @id @default(autoincrement())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   Int
  referee   Referee  @relation(fields: [refereeId], references: [id], onDelete: Cascade)
  refereeId Int
  role      String

  @@unique([matchId, refereeId])
  @@map("match_assignments")
}

model LoginAttempt {
  id           Int      @id @default(autoincrement())
  ipAddress    String   @unique
  attempts     Int      @default(0)
  lastAttempt  DateTime @default(now())
  blockedUntil DateTime?

  @@map("login_attempts")
}

model Question {
  id            Int      @id @default(autoincrement())
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String   // "A", "B", "C", or "D"
  category      String?  // Optional categorization
  difficulty    String   @default("Orta") // "Kolay", "Orta", "Zor"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("questions")
}

model ExamAttempt {
  id             Int      @id @default(autoincrement())
  referee        Referee  @relation(fields: [refereeId], references: [id], onDelete: Cascade)
  refereeId      Int
  score          Int      // Score out of 20
  totalQuestions Int      @default(20)
  difficulty     String?  // Difficulty level taken: "Kolay", "Orta", "Zor"
  answers        UserAnswer[]
  createdAt      DateTime @default(now())
  
  @@map("exam_attempts")
}

model UserAnswer {
  id             Int          @id @default(autoincrement())
  attempt        ExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  attemptId      Int
  questionId     Int          // Store question ID to track which question was answered
  questionText   String       // Store snapshot of question
  selectedAnswer String       // "A", "B", "C", or "D"
  correctAnswer  String       // Snapshot of correct answer
  isCorrect      Boolean
  
  @@map("user_answers")
}

model VideoCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  displayOrder Int     @default(0) // For sorting categories
  videos      Video[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("video_categories")
}

model Video {
  id          Int      @id @default(autoincrement())
  title       String
  url         String   // YouTube URL
  description String?
  category    String?  // Legacy field, kept for backward compatibility
  duration    Int      // Duration in seconds (optional, fetched from API or manual)
  viewCount   Int      @default(0) // Track video views
  
  // New category relation
  videoCategory   VideoCategory? @relation(fields: [videoCategoryId], references: [id], onDelete: SetNull)
  videoCategoryId Int?
  
  progress    VideoProgress[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("videos")
}

model VideoProgress {
  id             Int      @id @default(autoincrement())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         Int
  video          Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  videoId        Int
  
  watched        Boolean  @default(false)
  lastPosition   Int      @default(0) // Seconds
  updatedAt      DateTime @updatedAt

  @@unique([userId, videoId])
  @@map("video_progress")
}

model ChatSession {
  id        String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  messages  Message[]
  title     String?   @default("Yeni Sohbet")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("chat_sessions")
}

model Message {
  id        String      @id @default(uuid())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  role      String      // "user" or "assistant"
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@map("messages")
}

model RuleBook {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  url         String?  // URL to PDF or resource
  content     String?  @db.Text // Extracted PDF text content
  category    String?  // Optional category
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("rule_books")
}

model PendingUpload {
  id        String        @id @default(uuid())
  filename  String
  type      String
  total     Int           @default(0)
  chunks    UploadChunk[]
  createdAt DateTime      @default(now())

  @@map("pending_uploads")
}

model UploadChunk {
  id              Int           @id @default(autoincrement())
  pendingUpload   PendingUpload @relation(fields: [pendingUploadId], references: [id], onDelete: Cascade)
  pendingUploadId String
  index           Int
  data            String        @db.Text

  @@map("upload_chunks")
}
